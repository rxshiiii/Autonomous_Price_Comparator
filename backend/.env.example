# Database (using Docker port 5433 to avoid conflict with local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://pricecomp:pricecomp123@localhost:5433/pricecomparator
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
SECRET_KEY=your-secret-key-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# GROQ API
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile

# Scraping (optional)
PROXY_URL=
USER_AGENT_POOL_SIZE=50
MAX_CONCURRENT_SCRAPES=5

# Email (optional - for Phase 5)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@pricecomparator.com

# Monitoring (optional - for Phase 9)
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development
